# 비밀키 (절대 커밋 금지)
.streamlit/secrets.toml

# 빌드/배포 산출물 (용량 큼 — Streamlit Cloud엔 불필요)
dist/
build/
python/
*.spec
*.lnk
*.zip

# 운영 데이터 (Supabase에 저장 — 공개 레포에 두지 않음)
config/lot_assignments.xlsx
config/lot_assignments_auto.xlsx
config/settings.json

# 런타임 임시/캐시/결과
tmp_uploads/
output/
__pycache__/
*.pyc
_cache_*.xlsx
*.bak.xlsx

# 워치리스트 데이터(공개 노출 방지 — 클라우드는 Supabase 사용)
jaego/watchlist.json

# 창고비교/재고분석 런타임 캐시·임시
warehouse/_*.xlsx
inventory/_tmp/
inventory/data/물품담당자.xlsx
inventory/data/backup/

# LOCK 변환기 런타임 임시
lock/_tmp/

# 창고 레이아웃 색칠 임시
paint/_tmp/

# ABC 재배치 분석기 임시
abc/_tmp/

# 외박스 요청 리스트 로컬 저장(공유는 Supabase)
box_request/_*.json
